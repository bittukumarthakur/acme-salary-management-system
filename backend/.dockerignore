node_modules
dist
coverage
generated

# Local environment / secrets (never bake into the image)
.env
.env.*

# VCS and tooling
.git
.gitignore
.dockerignore
Dockerfile
docker-compose.yml

# Docs and planning notes
plans
*.md

# Logs
npm-debug.log
yarn-error.log
